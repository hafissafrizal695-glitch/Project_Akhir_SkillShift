{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "NIXPACKS",
    "src": {
      "path": "./"
    }
  },
  "deploy": {
    "numReplicas": 1,
    "healthCheckPath": "/api/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "node server/index.js"
  }
}
